# ── OpexIA observability ─────────────────────────────────────────────
# Fill these in; NEVER commit real values. Copy to .env (gitignored) locally.
# The workspace API key (opx_live_… / opx_test_…) — treat as a secret.
OPEXIA_ORG_ID=
OPEXIA_WORKSPACE_ID=
OPEXIA_PROJECT_ID=default
OPEXIA_API_KEY=
OPEXIA_INGEST_URL=https://ingest.opexia.dev

# opexia-trace Python SDK only: "direct" (POST straight to ingest, no collector)
# or "collector" (OTLP/gRPC to a collector you run). Default here is direct.
OPEXIA_TRANSPORT=direct

# ── Native OpenTelemetry export (Route 0: Next.js / Node / OTel-Python) ──
# Only needed on the native-OTLP route. Derived from the values above so the
# two never disagree. MUST be http/json — protobuf export returns 415.
OTEL_EXPORTER_OTLP_ENDPOINT=https://ingest.opexia.dev
OTEL_EXPORTER_OTLP_TRACES_PROTOCOL=http/json
OTEL_EXPORTER_OTLP_HEADERS=x-opexia-api-key=REPLACE_WITH_OPEXIA_API_KEY
